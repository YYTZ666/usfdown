---
import { ViewTransitions } from 'astro:transitions';
import '../assets/style.css';
import fallbackData from '../../public/versions_temp.json';

let versions = [];
try {
    const response = await fetch('https://raw.githubusercontent.com/Bedrock-OSS/BDS-Versions/main/versions.json');
    if (response.ok) {
        const data = await response.json();
        versions = data.windows?.versions || [];
    } else {
        versions = fallbackData.windows?.versions || [];
    }
} catch (error) {
    console.error('Fetch versions failed, using fallback data:', error);
    versions = fallbackData.windows?.versions || [];
}

const currentYear = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
